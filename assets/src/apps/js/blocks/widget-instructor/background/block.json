{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 2,
	"name": "learnpress/instructor-background",
	"title": "Instructor Background",
	"category": "lp-instructor-category",
	"icon": "format-image",
	"description": "Renders Template Instructor Background PHP templates.",
	"textdomain": "learnpress",
	"keywords": ["instructor background course", "learnpress"],
	"usesContext": [],
	"attributes": {
		"position": {
			"type": "string",
			"default": "center"
		},
		"size": {
			"type": "string",
			"default": "cover"
		},
		"repeat": {
			"type": "boolean",
			"default": false
		}
	},
	"supports": {
		"inserter": true,
		"reusable": true,
		"reorder": true,
		"html": false,
		"multiple": false
	},
	"ancestor": ["learnpress/lp-instructor"]
}
